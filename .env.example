# Copy this file to `.env.local` for local development (Next.js loads it automatically; do not commit secrets).
#
# Resend (https://resend.com) — server-only; never expose to the client
RESEND_API_KEY=re_xxxxxxxx

# Verified sender in Resend (your domain or Resend’s onboarding address for tests)
# Example: "Nanjundan Lab <contact@yourdomain.edu.au>"
RESEND_FROM_EMAIL="Nanjundan Lab <onboarding@resend.dev>"

# Inbox(es) for contact form (optional). Comma- or space-separated. If unset, uses site.email plus
# site.contactFormAdditionalRecipients from src/lib/content.ts
# CONTACT_TO_EMAIL=ashok.nanjundan@unisq.edu.au, colleague@unisq.edu.au
#
# With onboarding@resend.dev, Resend often only allows certain “to” addresses until you verify a domain.
# For local testing you can force a single recipient (development only):
# RESEND_DEV_TO=you@example.com

